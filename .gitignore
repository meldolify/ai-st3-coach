# Dependencies
node_modules/
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables (NEVER commit these!)
.env
.env.local
.env.production
.env.*.local

# Google Cloud credentials (NEVER commit!)
credentials.json
*-credentials.json
service-account*.json
google-tts-key.json
backend/google-tts-key.json

# Google OAuth client secrets (NEVER commit!)
client_secret_*.json

# API keys and secrets
*.key
*.pem

# Ad-hoc credential dumps (NEVER commit raw secrets to plaintext files!)
# These patterns catch the kind of file that triggered the 2026-05-17 audit.
**/supabase information.txt
**/supabase-information.txt
*supabase*information*
*secrets*.txt
*credentials*.txt
*password*.txt

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE files (keep .vscode/ for shared team configs)
.idea/
*.swp
*.swo
*~
.vscode/chrome-debug-profile/
.vscode/edge-debug-profile/

# Logs
logs/
*.log

# Temporary files
tmp/
temp/
*.tmp

# Build outputs
dist/
build/

# Testing
coverage/
backend/test-results/
backend/test-scripts/_generated/
.nyc_output/
*.test.js.snap
backend/__tests__/temp_*
e2e-tests/screenshots/
e2e-tests/videos/
e2e-tests/test-results/
e2e-tests/playwright-report/
playwright-report/
test-results/

# Claude Code cache
.claude/

# Claude temporary working directories
tmpclaude-*-cwd

# Playwright MCP screenshots
.playwright-mcp/

# MCP config (local)
.mcp.json

# Misc screenshots
*.png
!frontend/**/*.png
!frontend-react/**/*.png

# Vite build-output mirrors of frontend-react/public/.
# Sources live in frontend-react/public/{audio,images}/ and are committed there.
# Anything copied to frontend/{audio,images/landing}/ at build time should not
# be tracked. Untracked legacy assets in frontend/images/landing/ (doctor-portrait,
# hero-{penlight,reflex-hammer,scalpel,stethoscope,tablet,textbook}, leaf-{1..3},
# why-{gap,problem,solution}) are kept on disk for possible future reuse but
# stay out of the changes list. Already-tracked files (hero-centerpiece.png,
# hero-marble-bg.jpg) are unaffected — gitignore doesn't untrack tracked files.
frontend/audio/
frontend/images/landing/*
!frontend/images/landing/hero-centerpiece.png
!frontend/images/landing/hero-marble-bg.jpg

nul
