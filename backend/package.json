{
  "name": "st3-coach-v4-backend",
  "version": "1.0.0",
  "description": "ST3 Plastic Surgery Interview Trainer - V4 Backend (Web Speech API + Gemini 2.5 Flash + Google TTS)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage --verbose",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,json,md}\""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@deepgram/sdk": "^5.1.0",
    "@google-cloud/text-to-speech": "^5.0.0",
    "@google/genai": "^1.41.0",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.39.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.0",
    "helmet": "^8.0.0",
    "onnxruntime-node": "^1.24.1",
    "openai": "^4.28.0",
    "stripe": "^14.14.0",
    "ws": "^8.18.0"
  },
  "keywords": [
    "medical",
    "interview",
    "training",
    "voice",
    "ai"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "eslint": "^8.56.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jest": "^27.9.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.2.4",
    "supertest": "^6.3.3"
  }
}
