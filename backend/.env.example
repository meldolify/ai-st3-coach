# ============================================
# AI ST3 Coach V4 - Backend Environment Configuration
# ============================================
# Copy to .env and fill in your values.
# See HANDOVER.md (repo root) for the dashboards each value comes from.

# ============================================
# REQUIRED
# ============================================

# Gemini API key — used for the LLM (gemini-2.5-flash) and Gemini TTS.
# Validated on startup; the server exits if this is missing.
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Google Cloud Text-to-Speech credentials (used as the Gemini TTS fallback).
# Local dev: point to a service-account JSON file.
# Production (Render): use GOOGLE_APPLICATION_CREDENTIALS_JSON below instead — paste the
# entire service-account JSON as a single string and the server will write it to /tmp.
GOOGLE_APPLICATION_CREDENTIALS=./google-tts-key.json
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}   # production only

# Deepgram API key — used for streaming STT (Deepgram Flux). Required at
# startup; the server exits if this is missing.
# Get one at: https://console.deepgram.com/
DEEPGRAM_API_KEY=

# ============================================
# OPTIONAL — Server
# ============================================

# Combined HTTP + WebSocket port (Render injects PORT automatically).
PORT=8080

# ============================================
# OPTIONAL — Auth + DB (Supabase)
# ============================================
# Without these, server-side auth/subscription checks are skipped (DEV_BYPASS_AUTH effectively).

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # service_role key, NOT the anon key

# ============================================
# OPTIONAL — Payments (Stripe)
# ============================================

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_MONTHLY=price_...   # £19.99/month
STRIPE_PRICE_ID_ANNUAL=price_...    # £119.99/year

# Frontend URL — used for Stripe success/cancel redirects and CORS allow-list.
FRONTEND_URL=https://www.reviva.live

# ============================================
# OPTIONAL — Prompt Lab
# ============================================
# Auto-enabled in dev. Set to true on Render to expose /prompt-lab in production.
PROMPT_LAB_ENABLED=false
# REQUIRED if PROMPT_LAB_ENABLED=true: comma-separated allowlist of admin emails
# (matched against the Supabase user's email after Bearer-token verification).
# Without this set, every Prompt Lab request returns 503.
PROMPT_LAB_ADMIN_EMAILS=
# Required only if PROMPT_LAB_ENABLED=true and you want the auto-commit-to-GitHub feature:
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# ============================================
# OPTIONAL — Local development
# ============================================
# Skip Supabase auth and subscription checks. Never enable in production.
DEV_BYPASS_AUTH=false

# Verbose VAD logging. Useful when tuning Silero thresholds.
DEBUG_VAD=false

# ============================================
# OPTIONAL — Error tracking (Sentry)
# ============================================
# Set in Render env vars once you've created a Sentry project. Leave blank
# locally — the SDK no-ops when unset, so unhandled errors only go to the
# Render log, not to your Sentry quota.
# Get one at: https://sentry.io (free developer plan = 5k events/month)
SENTRY_DSN=

# ============================================
# OPTIONAL — Cost caps
# ============================================
# Per-user daily audio-minute caps. Defense in depth against a runaway
# user racking up Deepgram + Gemini cost. Defaults shown below; override
# in Render env to tighten/loosen. Set 0 to disable.
DAILY_AUDIO_MINUTES_FREE=30
DAILY_AUDIO_MINUTES_PREMIUM=240

# Global daily LLM call kill-switch. If the server crosses this many LLM
# calls in a UTC day across ALL users, every further request returns a
# soft "service unavailable" error. Operator-defined budget ceiling. Set
# 0 to disable. Rough sizing: a typical interview uses 5-15 LLM turns;
# 500 turns/day = ~30-60 interviews = several pounds of Gemini spend.
MAX_DAILY_LLM_CALLS=0
