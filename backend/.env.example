# ============================================
# AI ST3 Coach V4 - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# Required variables must be set for the app to run
# Optional variables enable additional features

# ============================================
# REQUIRED - Core Functionality
# ============================================

# OpenAI API Key (for Whisper STT)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Google Cloud Text-to-Speech credentials
# Place your service account JSON key file in this directory
# See INTEGRATION_GUIDE.md for setup instructions
GOOGLE_APPLICATION_CREDENTIALS=./google-tts-key.json

# ============================================
# OPTIONAL - Server Configuration
# ============================================

# WebSocket server port (default: 8080)
PORT=8080

# HTTP server port for health checks (default: 3000)
HTTP_PORT=3000

# ============================================
# OPTIONAL - Authentication (Supabase)
# Without these, app runs in demo mode (no login required)
# ============================================

# Supabase project URL
# Find at: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key (NOT the anon key)
# Find at: Supabase Dashboard > Project Settings > API > service_role
SUPABASE_SERVICE_KEY=eyJ...your-service-key

# ============================================
# OPTIONAL - Payments (Stripe)
# Without these, subscription features are disabled
# ============================================

# Stripe secret key (use test key for development)
# Find at: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook signing secret
# Find at: https://dashboard.stripe.com/test/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe price IDs for subscription products
# Find at: https://dashboard.stripe.com/test/products
# Monthly subscription (e.g., £14.99/month)
STRIPE_PRICE_ID_MONTHLY=price_...
# Annual subscription (e.g., £119.99/year)
STRIPE_PRICE_ID_ANNUAL=price_...
# Legacy fallback (optional, defaults to STRIPE_PRICE_ID_MONTHLY)
STRIPE_PRICE_ID=price_...

# Frontend URL for payment redirects
FRONTEND_URL=https://your-frontend-url.com
